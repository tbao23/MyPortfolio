<div class="contact-grid">
    <div class="contact-card">
        <div class="contact-card-label">email</div>
        <div class="contact-card-value">
            <a href="@SiteConfig.EmailHref">@SiteConfig.Email</a>
        </div>
    </div>
    <div class="contact-card">
        <div class="contact-card-label">github</div>
        <div class="contact-card-value">
            <a href="@SiteConfig.GitHubUrl" target="_blank" rel="noopener">github.com/@SiteConfig.GitHubUsername</a>
        </div>
    </div>
    <div class="contact-card">
        <div class="contact-card-label">linkedin</div>
        <div class="contact-card-value">
            <a href="@SiteConfig.LinkedInUrl" target="_blank" rel="noopener">@SiteConfig.LinkedInUrl.Replace("https://", "")</a>
        </div>
    </div>
</div>
