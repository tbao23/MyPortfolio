<div class="projects-tabs">
    <button class="projects-tab @(_tab == "personal" ? "active" : "")" @onclick='() => _tab = "personal"'>personal</button>
    <button class="projects-tab @(_tab == "school"   ? "active" : "")" @onclick='() => _tab = "school"'>school</button>
    <button class="projects-tab @(_tab == "oss"      ? "active" : "")" @onclick='() => _tab = "oss"'>open source</button>
</div>

@if (_tab == "personal")
{
    <ReposPanel />
}
else if (_tab == "school")
{
    @if (PortfolioContent.SchoolProjects.Length == 0)
    {
        <div class="status-text">no school projects yet.</div>
    }
    else
    {
        <div class="school-projects-list">
            @foreach (var p in PortfolioContent.SchoolProjects)
            {
                <div class="project-card">
                    <div class="project-card-header">
                        <a class="project-name" href="@p.Url" target="_blank" rel="noopener">@p.Name</a>
                        <span class="project-context">@p.OrgAndCourse</span>
                    </div>
                    <div class="project-desc">@p.Description</div>
                    <div class="project-tags">
                        @foreach (var tag in p.Tags)
                        {
                            <span class="tag">@tag.ToLower()</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
}
else if (_tab == "oss")
{
    @if (PortfolioContent.OpenSourceContributions.Length == 0)
    {
        <div class="status-text">contributions coming soon.</div>
    }
    else
    {
        <div class="oss-list">
            @foreach (var c in PortfolioContent.OpenSourceContributions)
            {
                <div class="project-card">
                    <div class="project-card-header">
                        <a class="project-name" href="@c.Url" target="_blank" rel="noopener">@c.Org / @c.Repo</a>
                    </div>
                    <div class="project-desc">@c.Description</div>
                    <div class="project-tags">
                        @foreach (var tag in c.Tags)
                        {
                            <span class="tag">@tag.ToLower()</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private string _tab = "personal";
}
